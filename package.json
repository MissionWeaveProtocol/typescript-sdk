{
  "name": "@missionweaveprotocol/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for MissionWeaveProtocol.",
  "license": "Apache-2.0",
  "author": "MissionWeaveProtocol Contributors",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "missionweaveprotocol-conformance": "./dist/bin/conformance.js"
  },
  "files": [
    "dist",
    "schemas",
    "conformance",
    "examples",
    "PROTOCOL_PIN.json",
    "LICENSE",
    "README*.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/missionweaveprotocol/typescript-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/missionweaveprotocol/typescript-sdk/issues"
  },
  "homepage": "https://missionweaveprotocol.github.io/",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "scripts": {
    "build": "tsup",
    "check": "npm run check:policy && npm run check:pin && npm run check:docs && npm run lint && npm run format:check && npm run typecheck && npm run typecheck:examples && npm run test && npm run build && npm run package:check && npm run package:smoke",
    "check:docs": "node scripts/check-docs.mjs",
    "check:pin": "node scripts/check-protocol-pin.mjs",
    "check:policy": "node scripts/check-repository-policy.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "package:check": "publint",
    "package:smoke": "node scripts/smoke-package.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p tsconfig.examples.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.43",
    "eslint": "^10.7.0",
    "globals": "^16.4.0",
    "prettier": "^3.9.5",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
